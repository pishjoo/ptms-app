generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TradeCaseType {
  IMPORT
  EXPORT
}

enum TradeCaseStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  COMPLETED
  CANCELLED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NTSWStatus {
  PENDING
  IN_PROGRESS
  UPDATED
  COMPLETED
  FAILED
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

enum DocumentStatus {
  PENDING
  UPLOADED
  REVIEWED
  APPROVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TimelineEventType {
  CREATED
  STATUS_UPDATED
  NTSW_UPDATED
  DOCUMENT_UPLOADED
  APPROVAL_CHANGED
  SHIPMENT_UPDATED
  CUSTOMS_UPDATED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyUsers  CompanyUser[]
  tradeCases    TradeCase[]      @relation("TradeCaseOwner")
  comments      TradeCaseComment[]
  statusHistory TradeCaseStatusHistory[] @relation("StatusChangedBy")
  documents     Document[]
  assignedTasks Task[]           @relation("TaskAssignee")
  timelineItems ProcessTimeline[] @relation("TimelineCreatedBy")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyUsers CompanyUser[]
  permissions  Permission[]

  @@index([slug])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles Role[]

  @@index([slug])
}

model Company {
  id                  String                @id @default(cuid())
  name                String
  code                String?               @unique
  country             String?
  status              CompanyStatus         @default(ACTIVE)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  companyUsers        CompanyUser[]
  tradeCases          TradeCase[]
  ntswProcesses       NTSWProcess[]
  registrationOrders  RegistrationOrder[]
  currencyRequests    CurrencyRequest[]
  customsDeclarations CustomsDeclaration[]
  shipments           Shipment[]
  documents           Document[]
  documentCategories  DocumentCategory[]
  tasks               Task[]
  timelines           ProcessTimeline[]

  @@index([status])
}

model CompanyUser {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  roleId      String
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([roleId])
}

model TradeCase {
  id                   String                  @id @default(cuid())
  companyId            String
  createdById          String?
  assignedCompanyUserId String?
  title                String
  referenceNo          String?                 @unique
  type                 TradeCaseType
  status               TradeCaseStatus         @default(DRAFT)
  priority             PriorityLevel           @default(MEDIUM)
  summary              String?
  externalReference    String?
  lastActivityAt       DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  company              Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy            User?                   @relation("TradeCaseOwner", fields: [createdById], references: [id], onDelete: SetNull)
  statusHistory        TradeCaseStatusHistory[]
  comments             TradeCaseComment[]
  ntswProcesses        NTSWProcess[]
  registrationOrders   RegistrationOrder[]
  currencyRequests     CurrencyRequest[]
  customsDeclarations CustomsDeclaration[]
  shipments            Shipment[]
  documents            Document[]
  tasks                Task[]
  timelines            ProcessTimeline[]

  @@index([companyId, status])
  @@index([companyId, status, updatedAt])
  @@index([createdById])
  @@index([referenceNo])
}

model TradeCaseStatusHistory {
  id              String          @id @default(cuid())
  tradeCaseId     String
  status          TradeCaseStatus
  note            String?
  changedByUserId String?
  createdAt       DateTime        @default(now())

  tradeCase       TradeCase       @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  changedBy       User?           @relation("StatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([tradeCaseId, createdAt])
}

model TradeCaseComment {
  id          String   @id @default(cuid())
  tradeCaseId String
  userId      String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tradeCase   TradeCase @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tradeCaseId, createdAt])
}

model NTSWProcess {
  id                  String                @id @default(cuid())
  companyId           String
  tradeCaseId         String
  referenceNo         String?
  status              NTSWStatus            @default(PENDING)
  summary             String?
  lastUpdatedAt       DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase           TradeCase             @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  registrationOrders  RegistrationOrder[]
  currencyRequests    CurrencyRequest[]
  customsDeclarations CustomsDeclaration[]
  shipments           Shipment[]

  @@index([companyId, status])
  @@index([tradeCaseId, status])
  @@index([referenceNo])
}

model RegistrationOrder {
  id           String        @id @default(cuid())
  companyId    String
  tradeCaseId  String
  ntswProcessId String?
  orderNumber  String?       @unique
  status       RequestStatus @default(DRAFT)
  submittedAt  DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase    TradeCase     @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  ntswProcess  NTSWProcess?  @relation(fields: [ntswProcessId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([tradeCaseId, status])
}

model CurrencyRequest {
  id             String        @id @default(cuid())
  companyId      String
  tradeCaseId    String
  ntswProcessId  String?
  requestNumber  String?       @unique
  currencyCode   String
  amount         Decimal?      @db.Decimal(12, 2)
  status         RequestStatus @default(DRAFT)
  requestedAt    DateTime?
  approvedAt     DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase      TradeCase     @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  ntswProcess    NTSWProcess?  @relation(fields: [ntswProcessId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([tradeCaseId, status])
}

model CustomsDeclaration {
  id                  String        @id @default(cuid())
  companyId           String
  tradeCaseId         String
  ntswProcessId       String?
  declarationNumber   String?       @unique
  customsOffice       String?
  status              RequestStatus @default(DRAFT)
  declarationDate     DateTime?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase           TradeCase     @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  ntswProcess         NTSWProcess?  @relation(fields: [ntswProcessId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([tradeCaseId, status])
}

model Shipment {
  id              String         @id @default(cuid())
  companyId       String
  tradeCaseId     String
  ntswProcessId   String?
  trackingNumber  String?        @unique
  carrier         String?
  status          ShipmentStatus @default(PENDING)
  departureDate   DateTime?
  arrivalDate     DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase       TradeCase      @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  ntswProcess     NTSWProcess?   @relation(fields: [ntswProcessId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([tradeCaseId, status])
}

model DocumentCategory {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@unique([companyId, slug])
  @@index([companyId, name])
}

model Document {
  id              String           @id @default(cuid())
  companyId       String
  tradeCaseId     String?
  categoryId      String?
  uploadedById    String?
  fileName        String
  storageKey      String           @unique
  mimeType        String?
  sizeBytes       Int?
  status          DocumentStatus   @default(PENDING)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase       TradeCase?       @relation(fields: [tradeCaseId], references: [id], onDelete: SetNull)
  category        DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  uploadedBy      User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, tradeCaseId, createdAt])
  @@index([tradeCaseId])
  @@index([categoryId])
}

model Task {
  id          String     @id @default(cuid())
  companyId   String
  tradeCaseId String
  assigneeId  String?
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase   TradeCase  @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([tradeCaseId, status])
  @@index([tradeCaseId, dueDate])
  @@index([assigneeId, status])
}

model ProcessTimeline {
  id                String            @id @default(cuid())
  companyId         String
  tradeCaseId       String
  createdById       String?
  eventType         TimelineEventType
  title             String
  description       String?
  metadata          Json?
  relatedEntityType String?
  relatedEntityId   String?
  occurredAt        DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tradeCase         TradeCase         @relation(fields: [tradeCaseId], references: [id], onDelete: Cascade)
  createdBy         User?             @relation("TimelineCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([tradeCaseId, eventType, occurredAt])
}
